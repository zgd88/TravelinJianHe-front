<!--pages/register/register.wxml-->
<view class="page">

  <!-- 步骤指示器 -->
  <view class="stepper">
    <view class="step-item">
      <view class="step-dot active">1</view>
    </view>
    <view class="step-line"></view>
    <view class="step-item">
      <view class="step-dot">2</view>
    </view>
    <view class="step-line"></view>
    <view class="step-item">
      <view class="step-dot">3</view>
    </view>
  </view>

  <!-- 错误提示 -->
  <view class="error-message" wx:if="{{errorMsg}}">
    <text>{{errorMsg}}</text>
  </view>

  <!-- 表单 -->
  <view class="form-area">
    <view class="input-group">
      <text class="input-label">手机号</text>
      <input class="input-field" type="number" placeholder="请输入手机号" maxlength="11"
        value="{{phone}}" bindinput="onPhoneInput"/>
    </view>

    <view class="input-group">
      <text class="input-label">密码</text>
      <input class="input-field" type="{{showPassword ? 'text' : 'password'}}" password="{{!showPassword}}"
        placeholder="请设置密码" maxlength="20"
        value="{{password}}" bindinput="onPasswordInput"/>
      <view class="pw-rules">
        <text>至少8位字符</text>
        <text>包含字母和数字</text>
        <text>不能与手机号相同</text>
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">确认密码</text>
      <input class="input-field" type="{{showPassword ? 'text' : 'password'}}" password="{{!showPassword}}"
        placeholder="请再次输入密码" maxlength="20"
        value="{{password2}}" bindinput="onPassword2Input"/>
    </view>

    <button class="btn btn-primary" bindtap="handleRegister" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '注册中...' : '注册'}}
    </button>
  </view>

</view>
