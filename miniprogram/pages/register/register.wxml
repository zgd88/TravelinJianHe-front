<!--pages/register/register.wxml-->
<view class="page">
  <view class="register-container">
    
    <view class="register-header">
      <text class="register-title">创建账号</text>
      <text class="register-subtitle">加入 Travel in JianHe</text>
    </view>

    <view class="error-message" wx:if="{{errorMsg}}">
      <text>⚠️ {{errorMsg}}</text>
    </view>

    <view class="input-group">
      <text class="input-label">手机号码</text>
      <view class="input-wrapper">
        <text class="input-icon-emoji">📱</text>
        <input 
          class="input-field" 
          type="number"
          placeholder="请输入手机号" 
          maxlength="11"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">设置密码</text>
      <view class="input-wrapper">
        <text class="input-icon-emoji">🔒</text>
        <input 
          class="input-field" 
          type="{{showPassword ? 'text' : 'password'}}" 
          password="{{!showPassword}}"
          placeholder="6-20位密码"
          maxlength="20"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
        <text class="toggle-pwd" bindtap="togglePassword">
          {{showPassword ? '🙈' : '👁'}}
        </text>
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">确认密码</text>
      <view class="input-wrapper">
        <text class="input-icon-emoji">🔒</text>
        <input 
          class="input-field" 
          type="{{showPassword2 ? 'text' : 'password'}}" 
          password="{{!showPassword2}}"
          placeholder="再次输入密码"
          maxlength="20"
          value="{{password2}}"
          bindinput="onPassword2Input"
        />
        <text class="toggle-pwd" bindtap="togglePassword2">
          {{showPassword2 ? '🙈' : '👁'}}
        </text>
      </view>
    </view>

    <button class="register-btn" bindtap="handleRegister" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '注册中...' : '注 册'}}
    </button>

    <view class="login-link" bindtap="goLogin">
      <text>已有账号？<text class="link-text">立即登录</text></text>
    </view>

  </view>
</view>