<!--pages/reset-password/reset-password.wxml-->
<view class="page">
  <view class="form-card">
    <text class="form-title">重置密码</text>
    <text class="form-sub">输入注册手机号和新密码</text>

    <view class="error-bar" wx:if="{{errorMsg}}">
      <text>{{errorMsg}}</text>
    </view>

    <view class="input-group">
      <text class="input-label">手机号</text>
      <input class="input-field" value="{{phone}}" bindinput="onPhoneInput" placeholder="请输入注册手机号" maxlength="11" type="number"/>
    </view>

    <view class="input-group">
      <text class="input-label">新密码</text>
      <view class="input-wrap">
        <input class="input-field" value="{{password}}" bindinput="onPasswordInput" placeholder="请输入新密码（6-20位）" maxlength="20" password="{{!showPassword}}"/>
        <text class="toggle-pwd" bindtap="togglePassword">{{showPassword ? '隐藏' : '显示'}}</text>
      </view>
    </view>

    <view class="input-group">
      <text class="input-label">确认新密码</text>
      <input class="input-field" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" placeholder="请再次输入新密码" maxlength="20" password="{{!showPassword}}"/>
    </view>

    <button class="submit-btn" bindtap="handleSubmit" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '提交中...' : '重置密码'}}
    </button>
  </view>
</view>
