<!--pages/admin-verify/admin-verify.wxml-->
<view class="page">
  <view class="header-bar">
    <text class="header-title">司机认证审核</text>
    <text class="header-count" wx:if="{{list.length > 0}}">{{list.length}} 条待审核</text>
  </view>

  <!-- 加载 -->
  <view class="loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 列表 -->
  <view class="verify-list" wx:if="{{!loading}}">
    <view class="verify-card" wx:for="{{list}}" wx:key="id">
      <view class="card-header" bindtap="showDetailPopup" data-item="{{item}}">
        <view class="card-user">
          <text class="card-name">{{item.real_name}}</text>
          <text class="card-phone">{{item.phone}}</text>
        </view>
        <text class="card-arrow">›</text>
      </view>
      <view class="card-info">
        <text class="card-plate">{{item.vehicle_plate}} · {{item.vehicle_color}} {{item.vehicle_model}}</text>
      </view>
      <view class="card-actions">
        <button class="action-btn reject-btn" bindtap="openReject" data-id="{{item.id}}">驳回</button>
        <button class="action-btn approve-btn" bindtap="approve" data-id="{{item.id}}">通过</button>
      </view>
    </view>

    <view class="empty" wx:if="{{list.length === 0}}">
      <text class="empty-icon">✅</text>
      <text class="empty-text">暂无待审核认证</text>
    </view>
  </view>
</view>

<!-- 详情弹窗 -->
<view class="modal-mask" wx:if="{{showDetail}}" bindtap="closeDetail">
  <view class="modal-box" catchtap="noop">
    <view class="modal-header">
      <text class="modal-title">认证详情</text>
      <text class="modal-close" bindtap="closeDetail">✕</text>
    </view>
    <view class="modal-body" wx:if="{{detailItem}}">
      <view class="detail-row"><text class="d-label">姓名</text><text class="d-value">{{detailItem.real_name}}</text></view>
      <view class="detail-row"><text class="d-label">身份证</text><text class="d-value">{{detailItem.id_card}}</text></view>
      <view class="detail-row"><text class="d-label">驾驶证</text><text class="d-value">{{detailItem.driver_license}}</text></view>
      <view class="detail-row"><text class="d-label">车牌号</text><text class="d-value">{{detailItem.vehicle_plate}}</text></view>
      <view class="detail-row"><text class="d-label">车型</text><text class="d-value">{{detailItem.vehicle_color}} {{detailItem.vehicle_model}}</text></view>
      <view class="detail-row"><text class="d-label">手机号</text><text class="d-value">{{detailItem.phone}}</text></view>
      <view class="detail-photos" wx:if="{{detailItem.id_card_photo || detailItem.driver_license_photo}}">
        <text class="d-label">证件照片</text>
        <view class="photos-row">
          <image wx:if="{{detailItem.id_card_photo}}" src="{{detailItem.id_card_photo}}" mode="aspectFill" class="photo" bindtap="previewPhoto" data-url="{{detailItem.id_card_photo}}"></image>
          <image wx:if="{{detailItem.driver_license_photo}}" src="{{detailItem.driver_license_photo}}" mode="aspectFill" class="photo" bindtap="previewPhoto" data-url="{{detailItem.driver_license_photo}}"></image>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn approve" bindtap="approve" data-id="{{detailItem.id}}">通过</button>
      <button class="modal-btn reject" bindtap="openReject" data-id="{{detailItem.id}}">驳回</button>
    </view>
  </view>
</view>

<!-- 驳回弹窗 -->
<view class="modal-mask" wx:if="{{showReject}}" bindtap="closeReject">
  <view class="modal-box small" catchtap="noop">
    <view class="modal-header">
      <text class="modal-title">驳回原因</text>
      <text class="modal-close" bindtap="closeReject">✕</text>
    </view>
    <view class="modal-body">
      <textarea class="reject-input" value="{{rejectReason}}" bindinput="onRejectReasonInput" placeholder="请填写驳回原因（如：身份证照片模糊）" maxlength="200"/>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="closeReject">取消</button>
      <button class="modal-btn approve" bindtap="submitReject" loading="{{processing}}">提交</button>
    </view>
  </view>
</view>
