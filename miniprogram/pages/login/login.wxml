<!--pages/login/login.wxml-->
<view class="page">
  <view class="login-container">

    <!-- 品牌区: Logo + 名称 -->
    <view class="brand-logo">
      <view class="logo-icon">
        <text class="logo-emoji">🚗</text>
      </view>
      <text class="logo-text">RideGo</text>
    </view>

    <!-- 错误提示 -->
    <view class="error-message" wx:if="{{errorMsg}}">
      <text>{{errorMsg}}</text>
    </view>

    <!-- 手机号 -->
    <view class="input-group">
      <text class="input-label">手机号</text>
      <input class="input-field" type="number" placeholder="请输入手机号" maxlength="11"
        value="{{phone}}" bindinput="onPhoneInput"/>
    </view>

    <!-- 密码 -->
    <view class="input-group">
      <text class="input-label">密码</text>
      <input class="input-field" type="{{showPassword ? 'text' : 'password'}}" password="{{!showPassword}}"
        placeholder="请输入密码" maxlength="20"
        value="{{password}}" bindinput="onPasswordInput"/>
    </view>

    <!-- 微信登录 -->
    <button class="btn btn-wx" bindtap="handleWxLogin" loading="{{loading}}" disabled="{{loading}}">
      微信一键登录
    </button>

    <view class="divider"><view class="divider-line"></view><text class="divider-text">或</text><view class="divider-line"></view></view>

    <!-- 手机号登录 -->
    <button class="btn btn-primary" bindtap="handleLogin" loading="{{loading}}" disabled="{{loading}}">
      {{loading ? '登录中...' : '登录'}}
    </button>

    <!-- 底部链接 -->
    <view class="bottom-links">
      <text class="link" bindtap="goRegister">注册新账号</text>
      <text class="link" bindtap="goForgot">忘记密码？</text>
    </view>

  </view>
</view>
