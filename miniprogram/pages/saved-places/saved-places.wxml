<view class="page">
  <view class="header-bar">
    <text class="header-title">收藏地址</text>
    <text class="header-action" bindtap="openAdd">+ 添加</text>
  </view>

  <!-- 地址列表 -->
  <view class="place-list" wx:if="{{places.length > 0}}">
    <view class="place-item" wx:for="{{places}}" wx:key="id" bindtap="selectPlace" data-item="{{item}}">
      <view class="place-left">
        <text class="label-tag">{{item.label}}</text>
      </view>
      <view class="place-info">
        <text class="place-addr">{{item.address}}</text>
      </view>
      <view class="place-del" catchtap="deletePlace" data-id="{{item.id}}">
        <text>🗑</text>
      </view>
    </view>
  </view>

  <view class="empty" wx:else>
    <text class="empty-icon">📍</text>
    <text class="empty-text">暂无收藏地址</text>
    <text class="empty-sub">点击右上角添加常用地点</text>
  </view>
</view>

<!-- 添加弹窗 -->
<view class="modal-mask" wx:if="{{showAdd}}" bindtap="closeAdd">
  <view class="modal-box" catchtap="noop">
    <view class="modal-header">
      <text class="modal-title">添加地址</text>
      <text class="modal-close" bindtap="closeAdd">✕</text>
    </view>
    <view class="modal-body">
      <view class="input-group">
        <text class="input-label">标签</text>
        <picker mode="selector" range="{{labels}}" value="{{labelIndex}}" bindchange="onLabelChange">
          <view class="picker-val">{{labels[labelIndex]}}</view>
        </picker>
      </view>
      <view class="input-group">
        <text class="input-label">地址</text>
        <input class="input-field" value="{{address}}" bindinput="onAddressInput" placeholder="输入地址或地图选点" maxlength="100"/>
      </view>
      <view class="input-row">
        <button class="small-btn" bindtap="pickLocation">🗺 地图选点</button>
        <button class="small-btn" bindtap="searchAddress">🔍 搜索地址</button>
      </view>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="closeAdd">取消</button>
      <button class="modal-btn confirm" bindtap="savePlace">保存</button>
    </view>
  </view>
</view>
