<view class="page">

  <!-- 认证状态横幅 -->
  <view wx:if="{{verifyStatus !== 'approved'}}" class="verify-banner {{verifyStatus === 'loading' ? 'verify-loading' : verifyStatus === 'none' ? 'verify-warning' : verifyStatus === 'pending' ? 'verify-pending' : 'verify-error'}}" bindtap="{{verifyStatus !== 'loading' ? 'goVerify' : ''}}">
    <text wx:if="{{verifyStatus === 'loading'}}">检查认证状态中...</text>
    <text wx:elif="{{verifyStatus === 'none'}}">⚠️ 您还未进行司机资质认证，点击去认证</text>
    <text wx:elif="{{verifyStatus === 'pending'}}">⏳ 资质审核中，请耐心等待</text>
    <text wx:elif="{{verifyStatus === 'rejected'}}">❌ 认证未通过：{{rejectReason}}，点击重新提交</text>
  </view>

  <!-- 顺风车进行中悬浮球 -->
  <view class="carpool-float" wx:if="{{hasOpenCarpool && verifyStatus === 'approved'}}" bindtap="goCarpoolDetail" data-id="{{carpoolOrders[0].id}}">
    <text class="float-icon">🚗</text>
  </view>

  <!-- 未认证遮罩 -->
  <view class="verify-overlay" wx:if="{{verifyStatus !== 'approved' && verifyStatus !== 'loading'}}">
    <text class="verify-overlay-icon">🪪</text>
    <text class="verify-overlay-text">完成司机资质认证后方可接单</text>
    <button class="verify-overlay-btn" bindtap="goVerify">去认证</button>
  </view>

  <block wx:if="{{verifyStatus === 'approved'}}">

    <!-- 在线接单开关 -->
    <view class="online-toggle">
      <view>
        <text class="online-title">在线接单</text>
        <text class="online-desc">开启后将自动接收附近订单</text>
      </view>
      <view class="toggle-switch {{isOnline ? 'on' : ''}}" bindtap="toggleOnline">
        <view class="toggle-knob"></view>
      </view>
    </view>

    <!-- 筛选栏 -->
    <view class="filter-bar">
      <view class="filter-chip {{activeTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">附近订单</view>
      <view class="filter-chip {{activeTab === 'mine' ? 'active' : ''}}" bindtap="switchTab" data-tab="mine">我的订单</view>
      <view class="filter-chip {{activeTab === 'carpool' ? 'active' : ''}}" bindtap="switchTab" data-tab="carpool">顺风车</view>
    </view>

    <!-- 附近待接订单 -->
    <scroll-view class="page-content" scroll-y wx:if="{{activeTab === 'pending'}}">
      <view class="order-list" wx:if="{{orders.length > 0}}">
        <view class="order-card-item" wx:for="{{orders}}" wx:key="id">
          <view class="order-header">
            <view>
              <view class="role-dot-d"></view>
              <text class="badge badge-warning">等待接单</text>
            </view>
            <text class="order-price">¥{{item.price}}</text>
          </view>
          <view class="order-route">
            <view class="route-dot bg-blue"></view>
            <text>{{item.pickup}}</text>
            <text class="route-arrow">›</text>
            <view class="route-dot bg-green"></view>
            <text>{{item.dest}}</text>
          </view>
          <view class="order-footer">
            <text class="footer-label">距您 {{item.driverDist || item.distance}}km</text>
            <button class="grab-btn" bindtap="acceptOrder" data-id="{{item.id}}">立即抢单</button>
          </view>
        </view>
      </view>
      <view class="empty" wx:else>
        <text class="empty-icon">🔔</text>
        <text class="empty-text">暂无附近订单</text>
        <text class="empty-sub">等待乘客下单中...</text>
      </view>
    </scroll-view>

    <!-- 我的订单 -->
    <scroll-view class="page-content" scroll-y wx:if="{{activeTab === 'mine'}}">
      <view class="sub-filter" wx:if="{{myOrders.length > 0}}">
        <view class="sub-chip {{myFilter === 'all' ? 'active' : ''}}" bindtap="setMyFilter" data-filter="all">全部</view>
        <view class="sub-chip {{myFilter === 'accepted' ? 'active' : ''}}" bindtap="setMyFilter" data-filter="accepted">已接单</view>
        <view class="sub-chip {{myFilter === 'running' ? 'active' : ''}}" bindtap="setMyFilter" data-filter="running">行程中</view>
        <view class="sub-chip {{myFilter === 'completed' ? 'active' : ''}}" bindtap="setMyFilter" data-filter="completed">已完成</view>
      </view>
      <view class="order-list" wx:if="{{filteredMyOrders.length > 0}}">
        <view class="order-card-item" wx:for="{{filteredMyOrders}}" wx:key="id" bindtap="goMyOrder" data-id="{{item.id}}">
          <view class="order-header">
            <view>
              <view class="role-dot-d"></view>
              <text class="badge {{item.status === 'completed' ? 'badge-success' : item.status === 'running' ? 'badge-info' : 'badge-warning'}}">{{item.statusText}}</text>
            </view>
            <text class="order-price" wx:if="{{item.price > 0}}">¥{{item.price}}</text>
          </view>
          <view class="order-route">
            <view class="route-dot bg-blue"></view>
            <text>{{item.pickup_addr || '上车点'}}</text>
            <text class="route-arrow">›</text>
            <view class="route-dot bg-green"></view>
            <text>{{item.dest_addr || '目的地'}}</text>
          </view>
          <view class="order-footer">
            <text class="footer-label">{{item.order_no}}</text>
            <text class="footer-label">{{item.departTime}}</text>
          </view>
        </view>
      </view>
      <view class="empty" wx:else>
        <text class="empty-icon">📋</text>
        <text class="empty-text">{{myFilter === 'all' ? '暂无订单' : '暂无该状态订单'}}</text>
      </view>
    </scroll-view>

    <!-- 顺风车 -->
    <scroll-view class="page-content" scroll-y wx:if="{{activeTab === 'carpool'}}">
      <view class="order-list" wx:if="{{carpoolOrders.length > 0}}">
        <view class="order-card-item" wx:for="{{carpoolOrders}}" wx:key="id" bindtap="goCarpoolDetail" data-id="{{item.id}}">
          <view class="order-header">
            <view>
              <view class="role-dot-d"></view>
              <text class="badge {{item.status === 'open' ? 'badge-success' : item.status === 'closed' ? 'badge-info' : 'badge-danger'}}">{{item.statusText}}</text>
            </view>
            <text class="order-price" wx:if="{{item.price > 0}}">¥{{item.price}}/人</text>
          </view>
          <view class="order-route">
            <view class="route-dot bg-blue"></view>
            <text>{{item.pickupAddr}}</text>
            <text class="route-arrow">›</text>
            <view class="route-dot bg-green"></view>
            <text>{{item.destAddr}}</text>
          </view>
          <view class="order-footer">
            <text class="footer-label">{{item.departTime}} 出发</text>
            <text class="footer-label">{{item.seats}}座</text>
          </view>
        </view>
      </view>
      <view class="empty" wx:else>
        <text class="empty-icon">🚗</text>
        <text class="empty-text">暂无顺风车行程</text>
        <text class="empty-sub" bindtap="goCarpoolPublish">发布一个顺风车</text>
      </view>
    </scroll-view>

  </block>

</view>
