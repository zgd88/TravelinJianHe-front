<!--pages/mine/mine.wxml-->
<view class="page">

  <!-- 头像区 — 原型 avatar-section -->
  <view class="avatar-section" bindtap="getUserAvatar">
    <view class="avatar-large">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"></image>
      <text wx:else class="avatar-emoji">🧑</text>
    </view>
    <view>
      <text class="user-name">{{nickname || 'RideGo用户'}}</text>
      <text class="user-phone">{{maskedPhone || '未绑定手机号'}}</text>
      <view class="role-badge-d">
        <text class="role-badge-text">{{roleText}}</text>
        <text class="role-switch-link" bindtap="switchRole">切换为{{role === 'driver' ? '乘客' : '司机'}}</text>
      </view>
    </view>
  </view>

  <!-- 统计卡 — 原型 stats-card -->
  <view class="stats-row">
    <view class="stat-item" bindtap="goOrderList" data-filter="all">
      <text class="stat-number">{{totalOrders}}</text>
      <text class="stat-label">总订单 ›</text>
    </view>
    <view class="stat-item">
      <text class="stat-number">¥{{totalAmount}}</text>
      <text class="stat-label">{{role === 'driver' ? '总收入' : '总消费'}}</text>
    </view>
    <view class="stat-item" bindtap="goOrderList" data-filter="completed">
      <text class="stat-number">{{completedOrders}}</text>
      <text class="stat-label">已完成 ›</text>
    </view>
  </view>

  <!-- 功能菜单 — 原型 menu-item -->
  <view class="menu-list">

    <!-- 收藏地址 -->
    <view class="menu-item" bindtap="onMenuTap" data-key="saved_places">
      <text class="menu-icon">📍</text>
      <text class="menu-text">收藏地址</text>
      <text class="menu-arrow">›</text>
    </view>

    <!-- 角色切换 -->
    <view class="menu-item" bindtap="switchRole">
      <text class="menu-icon">🔄</text>
      <text class="menu-text">切换角色</text>
      <text class="menu-arrow">›</text>
    </view>

    <!-- 司机认证（仅司机） -->
    <view class="menu-item" wx:if="{{role === 'driver'}}" bindtap="onMenuTap" data-key="verify">
      <text class="menu-icon">🪪</text>
      <text class="menu-text">司机认证
        <text wx:if="{{verifyStatus === 'approved'}}" class="verify-tag approved">已认证</text>
        <text wx:elif="{{verifyStatus === 'pending'}}" class="verify-tag pending">审核中</text>
        <text wx:elif="{{verifyStatus === 'rejected'}}" class="verify-tag rejected">未通过</text>
        <text wx:elif="{{verifyStatus === 'none'}}" class="verify-tag none">去认证</text>
      </text>
      <text class="menu-arrow">›</text>
    </view>

    <!-- 安全设置 -->
    <view class="menu-item" bindtap="onMenuTap" data-key="settings">
      <text class="menu-icon">🔐</text>
      <text class="menu-text">安全设置</text>
      <text class="menu-arrow">›</text>
    </view>

    <!-- 帮助与反馈 -->
    <view class="menu-item" bindtap="onMenuTap" data-key="help">
      <text class="menu-icon">❓</text>
      <text class="menu-text">帮助与反馈</text>
      <text class="menu-arrow">›</text>
    </view>

    <!-- 退出登录 — 原型 danger 色 -->
    <view class="menu-item logout-item" bindtap="logout">
      <text class="menu-icon logout-icon">🚪</text>
      <text class="menu-text logout-text">退出登录</text>
      <text class="menu-arrow logout-arrow">›</text>
    </view>

  </view>

</view>

<!-- 昵称编辑弹窗 -->
<view class="modal-mask" wx:if="{{showNicknameModal}}" bindtap="closeNicknameModal">
  <view class="modal-box" catchtap="noop">
    <view class="modal-header">
      <text class="modal-title">修改昵称</text>
      <text class="modal-close" bindtap="closeNicknameModal">✕</text>
    </view>
    <view class="modal-body">
      <input class="nickname-input" value="{{editingNickname}}" bindinput="onNicknameInput" maxlength="20" placeholder="请输入昵称"/>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel" bindtap="closeNicknameModal">取消</button>
      <button class="modal-btn confirm" bindtap="saveNickname">保存</button>
    </view>
  </view>
</view>
