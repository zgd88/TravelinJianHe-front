<view class="page">
  <view class="container">
    <text class="title">选择身份</text>
    <text class="subtitle">您想使用哪种服务？</text>

    <view class="role-card" bindtap="choosePassenger">
      <text class="role-emoji">🚗</text>
      <view class="role-info">
        <text class="role-name">我是乘客</text>
        <text class="role-desc">叫车出行</text>
      </view>
      <text class="role-arrow">›</text>
    </view>

    <view class="role-card" bindtap="chooseDriver">
      <text class="role-emoji">🧑‍✈️</text>
      <view class="role-info">
        <text class="role-name">我是司机</text>
        <text class="role-desc">接单赚钱</text>
      </view>
      <text class="role-arrow">›</text>
    </view>
  </view>
</view>