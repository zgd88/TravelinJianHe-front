<view class="page">

  <text class="subtitle">选择您的出行身份</text>

  <view class="role-card role-card-passenger" bindtap="choosePassenger">
    <view class="role-icon-wrap">
      <text class="role-emoji">🧑</text>
    </view>
    <text class="role-title">我要打车</text>
    <text class="role-desc">作为乘客出行，快速呼叫车辆</text>
  </view>

  <view class="role-card role-card-driver" bindtap="chooseDriver">
    <view class="role-icon-wrap">
      <text class="role-emoji">🚗</text>
    </view>
    <text class="role-title">我要接单</text>
    <text class="role-desc">作为司机接单赚钱，需要先完成认证</text>
  </view>

</view>
