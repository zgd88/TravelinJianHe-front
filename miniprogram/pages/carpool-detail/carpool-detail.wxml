<view class="page">
  <view class="loading" wx:if="{{loading}}">加载中...</view>

  <block wx:if="{{carpool}}">
    <view class="status-banner status-{{carpool.status}}">
      <text>{{carpool.statusText}}</text>
    </view>

    <view class="card">
      <view class="route">
        <view class="route-item"><view class="dot pickup"></view><text class="addr">{{carpool.pickupAddr}}</text></view>
        <view class="route-line"></view>
        <view class="route-item"><view class="dot dest"></view><text class="addr">{{carpool.destAddr}}</text></view>
      </view>

      <view class="info-grid">
        <view class="info-item"><text class="info-label">发车时间</text><text class="info-value">{{carpool.departTime}}</text></view>
        <view class="info-item"><text class="info-label">可坐人数</text><text class="info-value">{{carpool.seats}}座</text></view>
        <view class="info-item"><text class="info-label">每人价格</text><text class="info-value">¥{{carpool.price}}</text></view>
        <view class="info-item"><text class="info-label">匹配状态</text><text class="info-value">{{carpool.displayStatus}}</text></view>
      </view>
    </view>

    <view class="btn-area" wx:if="{{carpool.status === 'open'}}">
      <button class="btn" bindtap="closeCarpool">结束行程</button>
    </view>
  </block>
</view>
