<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-item {{selected === index ? 'active' : ''}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <text class="tab-icon">{{selected === index ? '◉' : '○'}}</text>
    <text class="tab-text">{{item.text}}</text>
  </view>
</view>
